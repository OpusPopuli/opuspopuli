{
  "info": {
    "_postman_id": "opus-populi-collection",
    "name": "OpusPopuli Backend",
    "description": "GraphQL API collection for OpusPopuli backend microservices.\n\nServices:\n- API Gateway (:3000) - federated gateway\n- Users (:3001) - auth, profiles, activity\n- Documents (:3002) - file management, OCR, analysis\n- Knowledge (:3003) - semantic search, RAG\n- Region (:3004) - civic data, scraping pipeline",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// CSRF double-submit cookie + Apollo preflight",
          "// Run 'Seed CSRF Token' request first to populate csrf_token env var",
          "const csrfToken = pm.environment.get('csrf_token');",
          "if (pm.request.method === 'POST') {",
          "    pm.request.headers.upsert({ key: 'apollo-require-preflight', value: 'true' });",
          "    if (csrfToken) {",
          "        pm.request.headers.upsert({ key: 'x-csrf-token', value: csrfToken });",
          "        pm.request.headers.upsert({ key: 'Cookie', value: 'csrf-token=' + csrfToken });",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],

    {
      "name": "Auth",
      "description": "Authentication flows.\n\nFor UAT testing, use 'Login via Supabase Auth' to get a JWT, then all subsequent requests use it automatically via the collection's Bearer auth.\n\nSetup: Run 'Seed CSRF Token' first, then 'Login via Supabase Auth'.",
      "item": [
        {
          "name": "Login via Supabase Auth (run this first!)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.access_token) {",
                  "    pm.environment.set('access_token', response.access_token);",
                  "    console.log('Access token saved to environment');",
                  "} else {",
                  "    console.log('Login failed:', JSON.stringify(response));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{supabase_anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{supabase_url}}/auth/v1/token?grant_type=password",
              "host": ["{{supabase_url}}"],
              "path": ["auth", "v1", "token"],
              "query": [{ "key": "grant_type", "value": "password" }]
            }
          }
        },
        {
          "name": "Register User (GraphQL)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation RegisterUser($input: RegisterUserDto!) {\n  registerUser(registerUserDto: $input)\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"{{test_email}}\",\n    \"username\": \"testuser\",\n    \"password\": \"{{test_password}}\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/api",
              "host": ["{{gateway_url}}"],
              "path": ["api"]
            }
          }
        },
        {
          "name": "Login User (GraphQL)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data.loginUser) {",
                  "    pm.environment.set('access_token', response.data.loginUser.accessToken);",
                  "    console.log('Access token saved to environment');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation LoginUser($input: LoginUserDto!) {\n  loginUser(loginUserDto: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"{{test_email}}\",\n    \"password\": \"{{test_password}}\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{gateway_url}}/api",
              "host": ["{{gateway_url}}"],
              "path": ["api"]
            }
          }
        },

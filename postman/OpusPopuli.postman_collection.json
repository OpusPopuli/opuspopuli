        {
          "name": "API Gateway - Seed CSRF Token (run first!)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Try multiple approaches to extract the CSRF token",
                  "",
                  "// Approach 1: Read from Postman cookie jar",
                  "var token = pm.cookies.get('csrf-token');",
                  "",
                  "// Approach 2: Parse Set-Cookie headers manually",
                  "if (!token) {",
                  "    pm.response.headers.each(function(header) {",
                  "        if (header.key.toLowerCase() === 'set-cookie') {",
                  "            var match = header.value.match(/csrf-token=([^;]+)/);",
                  "            if (match) { token = match[1]; }",
                  "        }",
                  "    });",
                  "}",
                  "",
                  "// Approach 3: Get raw response headers as string",
                  "if (!token) {",
                  "    var raw = pm.response.headers.toString();",
                  "    var match = raw.match(/csrf-token=([0-9a-f-]{36})/);",
                  "    if (match) { token = match[1]; }",
                  "}",
                  "",
                  "if (token && token.indexOf('{') === -1) {",
                  "    pm.environment.set('csrf_token', token);",
                  "    console.log('CSRF token saved: ' + token);",
                  "} else {",
                  "    console.log('WARNING: Could not extract CSRF token. Headers:', pm.response.headers.toString());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "apollo-require-preflight", "value": "true" }],
            "url": {
              "raw": "{{gateway_url}}/api",
              "host": ["{{gateway_url}}"],
              "path": ["api"]
            }
          }
        },
        {
          "name": "Prompt Service - Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{prompt_service_url}}/health",
              "host": ["{{prompt_service_url}}"],
              "path": ["health"]
            }
          }
        }
      ]

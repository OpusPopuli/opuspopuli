{
  "name": "@opuspopuli/queue-provider",
  "version": "0.1.0",
  "description": "BullMQ-based async job queue provider for Opus Populi",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",

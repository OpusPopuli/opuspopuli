    "ioredis": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.0.0",
    "jest-mock-extended": "^4.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0"
  }

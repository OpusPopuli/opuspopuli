{
  "threshold": 0,
  "minLines": 8,
  "minTokens": 60,
  "languages": ["typescript"],
  "formatsExts": { "typescript": ["ts", "tsx"] },
  "noSymlinks": true,
  "path": [
    "apps/backend/src",
    "apps/frontend/app",
    "apps/frontend/lib",
    "packages/auth-provider/src",
    "packages/common/src",
    "packages/config-provider/src",
    "packages/email-provider/src",
    "packages/embeddings-provider/src",
    "packages/extraction-provider/src",
    "packages/llm-provider/src",
    "packages/logging-provider/src",
    "packages/ocr-provider/src",
    "packages/prompt-client/src",
    "packages/region-provider/src",
    "packages/relationaldb-provider/src",
    "packages/scraping-pipeline/src",
    "packages/secrets-provider/src",
    "packages/storage-provider/src",
    "packages/vectordb-provider/src"
  ],
  "ignore": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "**/*.dto.ts",
    "**/*.model.ts",
    "**/*.module.ts",
    "**/migrations/**",
    "**/generated/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/coverage/**"
  ],
  "reporters": ["consoleFull"],
  "exitCode": 1
}

# --- Build artifacts ---
node_modules
dist
.next
npm-debug.log
coverage
playwright-report
*.tsbuildinfo

# --- Version control ---
.git
.github

# --- Infrastructure (not part of any application image) ---
infra
infra-backup

# --- Local dev data ---
supabase
# Re-include supabase/migrations so backend images can apply vault RPCs
# via pg-meta at startup (#742). The rest of supabase/ stays excluded —
# volumes/, init/, etc. are dev-host concerns.
!supabase/migrations
observability
tmp

# --- Documentation and dev tooling ---
docs
postman
scripts

# --- IDE and tooling config ---
.claude
.husky
.vscode
.sonarlint
.DS_Store
.editorconfig
.gitleaks.toml
.jscpd.json
renovate.json

# --- Docker files (not needed inside images) ---
Dockerfile
.dockerignore
docker-compose*.yml

# --- Environment files (security) ---
.env
.env.*

# --- Documentation files ---
*.md
!README.md
LICENSE

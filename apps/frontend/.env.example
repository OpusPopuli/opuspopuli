# Frontend Environment Variables

# GraphQL API endpoint (backend API gateway)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3000/api

# GraphQL WebSocket endpoint (for subscriptions — auto-derived from HTTP URL if omitted)
# NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:3000/api

# Public site URL (used for SEO meta tags, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3200

# HMAC Authentication (for frontend-to-gateway request signing)
NEXT_PUBLIC_HMAC_CLIENT_ID=frontend
NEXT_PUBLIC_HMAC_SECRET=dev-frontend-secret-key-change-in-production

# Content Security Policy violation reporting (optional)
# CSP_REPORT_URI=

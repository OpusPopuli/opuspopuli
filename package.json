{
  "name": "opuspopuli",
  "version": "1.0.0",
  "description": "Full-stack civic technology platform with Next.js, NestJS, and 100% OSS AI/ML",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test -- --coverage",
    "test:integration": "pnpm --filter backend test:integration",
    "test:integration:docker": "bash scripts/test-integration-docker.sh",
    "integration:up": "docker compose -f docker-compose-integration.yml up -d --build",
    "integration:down": "docker compose -f docker-compose-integration.yml down -v",
    "integration:logs": "docker compose -f docker-compose-integration.yml logs -f",
    "uat:up": "docker compose -f docker-compose-uat.yml up -d --build",
    "uat:down": "docker compose -f docker-compose-uat.yml down",
    "uat:down:clean": "docker compose -f docker-compose-uat.yml down -v",
    "uat:logs": "docker compose -f docker-compose-uat.yml logs -f",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "**/*.+(js|jsx|ts|tsx)": [
      "pnpm -r lint",
      "pnpm -r format"
    ],
    "**/*.+(json|css)": [
      "pnpm -r format"
    ]
  },
  "dependencies": {
    "cockatiel": "^3.2.1"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "fast-xml-parser": ">=5.5.6",
      "lodash": ">=4.17.23",
      "langsmith": ">=0.4.6",
      "@apollo/gateway": ">=2.12.3",
      "@apollo/query-planner": ">=2.12.3",
      "@apollo/federation-internals": ">=2.12.3",
      "undici": ">=7.24.0",
      "flatted": ">=3.4.0",
      "file-type": ">=21.3.1",
      "hono": ">=4.12.7",
      "next": ">=16.1.7"
    }
  }
}

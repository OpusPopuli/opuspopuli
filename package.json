{
  "name": "opuspopuli",
  "version": "1.0.1",
  "description": "Full-stack civic technology platform with Next.js, NestJS, and 100% OSS AI/ML",
  "main": "index.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test -- --coverage",
    "test:integration": "pnpm --filter backend test:integration",
    "test:integration:docker": "bash scripts/test-integration-docker.sh",
    "integration:up": "docker compose -f docker-compose-integration.yml up -d --build",
    "integration:down": "docker compose -f docker-compose-integration.yml down -v",
    "integration:logs": "docker compose -f docker-compose-integration.yml logs -f",
    "uat:up": "docker compose -f docker-compose-uat.yml up -d --build",
    "uat:down": "docker compose -f docker-compose-uat.yml down",
    "uat:down:clean": "docker compose -f docker-compose-uat.yml down -v",
    "uat:logs": "docker compose -f docker-compose-uat.yml logs -f",
    "prepare": "husky",
    "lint:sonar": "pnpm -r lint:sonar",
    "jscpd": "jscpd",
    "db:load-ca-boundaries": "ts-node scripts/load-ca-boundaries.ts"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0",
  "devDependencies": {
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "^9.1.7",
    "jscpd": "^4.1.0",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "**/*.+(js|jsx|ts|tsx)": [
      "pnpm -r lint",
      "pnpm -r format"
    ],
    "**/*.+(json|css)": [
      "pnpm -r format"
    ]
  },
  "dependencies": {
    "cockatiel": "^3.2.1"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "fast-xml-parser": ">=5.7.0",
      "fast-xml-builder": ">=1.1.7",
      "fast-uri": ">=3.1.2",
      "lodash": ">=4.18.0",
      "langsmith": ">=0.5.19",
      "protobufjs": ">=7.5.5",
      "protocol-buffers-schema": ">=3.6.1",
      "postcss": ">=8.5.10",
      "ip-address": ">=10.1.1",
      "brace-expansion": "^2.0.3",
      "@apollo/gateway": ">=2.12.3",
      "@apollo/query-planner": ">=2.12.3",
      "@apollo/federation-internals": ">=2.12.3",
      "undici": ">=7.24.0",
      "flatted": ">=3.4.2",
      "file-type": ">=21.3.1",
      "hono": ">=4.12.7",
      "next": ">=16.2.3",
      "handlebars": ">=4.7.9",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "defu": ">=6.1.5",
      "axios": ">=1.15.0",
      "basic-ftp": ">=5.2.1",
      "next@>=16.0.0 <16.2.6": ">=16.2.6",
      "@opentelemetry/auto-instrumentations-node@<0.75.0": ">=0.75.0",
      "@opentelemetry/sdk-node@<0.217.0": ">=0.217.0",
      "@opentelemetry/exporter-prometheus@<0.217.0": ">=0.217.0"
    }
  }
}

coverage

node_modules
.env

.terraform
*.tfplan

*.tfvars

# NestJS GraphQL autoSchemaFile output (region service) — regenerated on every build
region-schema.gql

# Build outputs
dist/
*.tsbuildinfo

# Infrastructure backup (old modules)
infra-backup/

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# TLS / cert material — generated at build time by Dockerfile.nginx,
# never committed. README in apps/frontend/nginx/.certs/ documents
# how to regenerate locally if you need them on disk for dev.
*.key
*.crt
*.pem
!**/test-fixtures/**/*.pem
!**/__fixtures__/**/*.pem

# macOS
.DS_Store

# Claude Code per-project state (worktrees, tool results, local settings)
# settings.json (team config) can be force-added if needed: git add -f .claude/settings.json
.claude/
tmp/

# Local scratch — planning notes, ad-hoc test plans, design sketches.
# Anything in here is intentionally out of git history.
.scratch/

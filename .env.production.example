# =============================================================================
# Production Environment Variables — Mac Studio + Cloudflare
# =============================================================================
#
# Copy to .env.production and fill in values:
#   cp .env.production.example .env.production
#
# Then start the stack:
#   docker compose -f docker-compose-prod.yml --env-file .env.production up -d --build
#
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare Tunnel
# -----------------------------------------------------------------------------
# Get this from: terraform output -raw tunnel_token
TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# Supabase Cloud (user-facing data)
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Local PostgreSQL (AI scratch data)
# -----------------------------------------------------------------------------
LOCAL_DB_PASSWORD=change-this-strong-password

# -----------------------------------------------------------------------------
# Auth & Security
# -----------------------------------------------------------------------------
# Generate secrets with: openssl rand -hex 32
# JWT_SECRET and AUTH_JWT_SECRET must be at least 32 characters
JWT_SECRET=generate-with-openssl-rand-hex-32
AUTH_JWT_SECRET=generate-with-openssl-rand-hex-32
GATEWAY_HMAC_SECRET=generate-with-openssl-rand-base64-32
API_KEYS='{"api-gateway":"<same-as-GATEWAY_HMAC_SECRET>","frontend":"<generate-a-separate-secret>"}'

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://opuspopuli.org,https://www.opuspopuli.org

# -----------------------------------------------------------------------------
# LLM (Ollama runs natively on macOS)
# -----------------------------------------------------------------------------
LLM_MODEL=qwen3.5:35b

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@opuspopuli.org
EMAIL_FROM_NAME=Opus Populi

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=https://opuspopuli.org

# -----------------------------------------------------------------------------
# Prisma Connection Pool
# -----------------------------------------------------------------------------
# PRISMA_CONNECTION_LIMIT=20    # Max connections per service
# PRISMA_POOL_TIMEOUT=10        # Seconds to wait for a connection

# -----------------------------------------------------------------------------
# Versioning
# -----------------------------------------------------------------------------
VERSION=1.0.0

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
